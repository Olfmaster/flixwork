# E-Mail-Versand der Anfragen (Konfigurator + Fragebogen) über Resend.
# Ohne RESEND_API_KEY werden Anfragen nur in der Server-Konsole geloggt
# (die Seite funktioniert trotzdem, es wird nur nichts verschickt).
RESEND_API_KEY=

# Zieladresse für Monteur-Konfigurator-Anfragen (Herr Wolf).
KONFIGURATOR_EMAIL=wolf@flixwork.de

# Zieladresse für Logistik-/Industrie-Anfragen.
ANFRAGE_EMAIL=info@flixwork.de

# Absender (muss in Resend als verifizierte Domain hinterlegt sein).
# Default nutzt die Resend-Sandbox-Adresse.
CONTACT_FROM=Flixwork Website <onboarding@resend.dev>
